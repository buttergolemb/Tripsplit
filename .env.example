# TripSplit API — required environment variables
#
# Copy to `.env` and fill in your values. The server reads these on startup.

# Postgres connection string. Examples:
#   Local:    postgres://tripsplit:tripsplit@localhost:5432/tripsplit
#   Render:   postgres://USER:PASS@HOST.oregon-postgres.render.com/DB?sslmode=require
#   Supabase: postgres://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres?sslmode=require
#   Neon:     postgres://USER:PASS@ep-xxx.us-east-1.aws.neon.tech/DB?sslmode=require
DATABASE_URL=postgres://tripsplit:tripsplit@localhost:5432/tripsplit

# Optional — force TLS behavior. Most hosted providers want `require`.
# PGSSLMODE=require

# API port (defaults to 4000).
# PORT=4000
